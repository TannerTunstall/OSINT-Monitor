# ============================================================
# OSINT Monitor — Environment Variables
# Copy to .env and fill in your values.
# Only uncomment what you need.
# ============================================================

# Telegram MTProto credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Signal sender phone number (only if using Signal notifier)
# SIGNAL_SENDER=+1234567890

# Cloudflare Radar API token (free — dash.cloudflare.com > My Profile > API Tokens)
# CLOUDFLARE_RADAR_TOKEN=

# Email SMTP credentials (only if using Email notifier)
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Generic webhook auth (referenced in config.yaml via ${WEBHOOK_TOKEN})
# WEBHOOK_TOKEN=

# WAHA image tag — set automatically by setup.sh
# Use "arm" for Apple Silicon / ARM64, "latest" for x86
# WAHA_TAG=latest
